# KilimoOrbit Sentinel — environment configuration
# Get a FREE Gemini API key (no credit card): https://aistudio.google.com/apikey
export const GEMINI_API_KEY = "your_gemini_api_key_here"; // <-- paste your free Gemini key here


# Optional overrides
# APEX_MODEL=gemini-2.5-flash
# APEX_MOCK=1          # force offline deterministic engine (no API calls)
# PORT=4517            # Mission Control dashboard port

# Welcome email on sign-in (POST /api/signin). Leave unset to run in
# SIMULATED mode (the email is logged to the server console instead).
# Either a single connection URL…
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# …or discrete settings (e.g. Gmail app password, Brevo, Mailtrap):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="KilimoOrbit Sentinel <you@gmail.com>"
